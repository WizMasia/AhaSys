# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# OCR_ENABLED: When 'false', server-side OCR (EasyOCR Python script) is
# skipped entirely. The non-vision OCR fallback path will tell the user
# that visual assessment is excluded and only the text input is reviewed.
# Set to 'false' on the Render demo deployment to avoid shipping the
# multi-gigabyte Python OCR stack; keep the default (enabled) for local
# development with .venv-ocr/ installed.
OCR_ENABLED="true"

# EASYOCR_LANGS: Comma-separated language codes passed to easyocr.Reader.
# Defaults to 'ko,en' for Korean + English. Common alternatives: 'ko',
# 'en', 'ko,en,ja'.
EASYOCR_LANGS="ko,en"

# EASYOCR_GPU: 'true' to enable CUDA (requires paddle/torch GPU build),
# 'false' (default) for CPU inference.
EASYOCR_GPU="false"

# OCR_PYTHON_BIN: Absolute path to the Python interpreter that runs the
# EasyOCR script. Defaults to the project's .venv-ocr/bin/python3.11.
OCR_PYTHON_BIN="/absolute/path/to/.venv-ocr/bin/python3.11"
